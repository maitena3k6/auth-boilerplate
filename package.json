{
    "name": "auth-boilerplate",
    "version": "1.0.0",
    "description": "A base Auth boilerplate API with JWT",
    "license": "ISC",
    "author": "Maitena Diaz",
    "main": "./build/src/server.js",
    "type": "commonjs",
    "scripts": {
        "prestart": "npm run build",
        "start": "node ./build/src/server.js",
        "start:dev": "nodemon -w src -e ts -r tsconfig-paths/register --exec ts-node ./src/server.ts",
        "dev": "concurrently \"npm run start:dev\"",
        "prebuild": "rimraf ./build",
        "build": "tsc && tsc-alias",
        "seed": "ts-node ./src/seed.ts",
        "typeorm": "typeorm-ts-node-commonjs",
        "typeorm:run": "npm run build && typeorm-ts-node-commonjs migration:run -d ./build/src/data-source.js",
        "typeorm:generate": "npm run build && typeorm-ts-node-commonjs migration:generate -d ./build/src/data-source.js",
        "typeorm:create": "typeorm-ts-node-commonjs migration:create",
        "typeorm:revert": "npm run build && typeorm-ts-node-commonjs migration:revert -d ./build/src/data-source.js"
    },
    "dependencies": {
        "@types/cors": "^2.8.19",
        "bcrypt": "^6.0.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-validator": "^7.3.2",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "pg": "^8.20.0",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.6.0",
        "concurrently": "^9.2.1",
        "eslint": "^10.2.1",
        "globals": "^17.5.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0"
    }
}
