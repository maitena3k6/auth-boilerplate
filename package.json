{
    "name": "auth-boilerplate",
    "version": "1.0.0",
    "description": "A base Auth boilerplate API with JWT",
    "license": "ISC",
    "author": "Maitena Diaz",
    "main": "src/server.js",
    "scripts": {
        "dev": "tsc --watch & NODE_ENV=development nodemon dist/server.js",
        "build": "tsc --project tsconfig.json",
        "start": "node dist/server.js",
        "clean": "rm -rf dist",
        "test": "echo \"Error: no test specified\" && exit 1",
        "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "migration:generate": "npm run typeorm migration:generate -- -d src/data-source.ts src/migrations/$npm_config_name",
        "migration:run": "npm run typeorm migration:run -- -d src/data-source.ts",
        "migration:revert": "npm run typeorm migration:revert -- -d src/data-source.ts",
        "migration:create": "npm run typeorm migration:create -- src/migrations/$npm_config_name",
        "seed": "ts-node src/seed.ts"
    },
    "dependencies": {
        "@types/cors": "^2.8.19",
        "bcrypt": "^6.0.0",
        "class-validator": "^0.15.1",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-api-utils": "^1.0.4",
        "express-validator": "^7.3.2",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "pg": "^8.20.0",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.6.0",
        "eslint": "^10.2.1",
        "globals": "^17.5.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.3",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0"
    }
}
